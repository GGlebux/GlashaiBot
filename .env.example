# ============================================================
#  Глашатай 📯 — пример конфигурации.
#  Скопируй в .env и заполни своими значениями:  cp .env.example .env
# ============================================================

# --- Telegram ---
# Токен бота от @BotFather
BOT_TOKEN=123456:ABC-DEF...
# Telegram user-id админов через запятую (узнать у @userinfobot)
ADMIN_IDS=11111111,22222222

# --- Лимиты использования ---
# Сколько голосовых/кружков может обработать один юзер в сутки
DAILY_LIMIT=20
# Максимальная длительность аудио в секундах (что дольше — отклоняем)
MAX_AUDIO_SECONDS=600

# --- SaluteSpeech (STT, распознавание речи) ---
# ВАРИАНТ 1: «Ключ авторизации» (Authorization key) — длинная Base64-строка
#            из кабинета developers.sber.ru -> SaluteSpeech. НЕ Client ID (UUID)!
SALUTE_SPEECH_AUTH_KEY=
# ВАРИАНТ 2 (если нет готового ключа): задай Client ID и Client Secret —
#            ключ соберётся автоматически. Заполняй ЛИБО вариант 1, ЛИБО вариант 2.
SALUTE_SPEECH_CLIENT_ID=
SALUTE_SPEECH_CLIENT_SECRET=
# Scope: для физлиц SALUTE_SPEECH_PERS, для юрлиц SALUTE_SPEECH_CORP
SALUTE_SPEECH_SCOPE=SALUTE_SPEECH_PERS

# --- GigaChat (LLM, краткое содержание) ---
# ВАРИАНТ 1: «Ключ авторизации» (Authorization key) — длинная Base64-строка.
GIGACHAT_AUTH_KEY=
# ВАРИАНТ 2: Client ID + Client Secret (соберём ключ сами).
GIGACHAT_CLIENT_ID=
GIGACHAT_CLIENT_SECRET=
# Scope: для физлиц GIGACHAT_API_PERS
GIGACHAT_SCOPE=GIGACHAT_API_PERS
# Модель: GigaChat | GigaChat-Pro | GigaChat-Max
GIGACHAT_MODEL=GigaChat

# --- База данных (PostgreSQL) ---
POSTGRES_DB=glashatai
POSTGRES_USER=glashatai
POSTGRES_PASSWORD=change-me-please
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Redis (очередь arq + сессии /begin) ---
REDIS_URL=redis://redis:6379/0

# --- Админ-панель ---
# Секрет для подписи сессионных cookie (любая длинная случайная строка)
ADMIN_SECRET_KEY=change-this-to-a-long-random-string
# Публичный адрес админки (нужен Telegram Login Widget). Например https://admin.example.com
ADMIN_BASE_URL=http://localhost:8080
# Порт, на котором админка слушает внутри контейнера
ADMIN_PORT=8080

# --- Деплой (прод, docker-compose.yml) ---
# Образ из Docker Hub, который тянут сервисы и обновляет Watchtower
DOCKER_IMAGE=yourdockerhubuser/glashatai:latest

# --- Прочее ---
LOG_LEVEL=INFO
TZ=Europe/Moscow
